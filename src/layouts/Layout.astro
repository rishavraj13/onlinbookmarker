---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SetupSupabase from '../components/SetupSupabase.astro';
import Auth from '../components/Auth.astro';
import { isSupabaseConfigured } from '../lib/supabaseClient';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="The ultimate custom bookmarker app. Save, organize, and manage your website bookmarks and AI conversations securely with the best bookmarker tool." />
    <meta name="keywords" content="bookmarker, bookmark, custom bookmark, bookmark or bookmarker, bookmarker app, website bookmarker" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="{title} | RBookmark - Custom Bookmarker App" />
    <meta property="og:description" content="The ultimate custom bookmarker app. Save, organize, and manage your website bookmarks securely." />
    <meta property="og:image" content="/og-image.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="{title} | RBookmark - Custom Bookmarker App" />
    <meta property="twitter:description" content="The ultimate custom bookmarker app. Save, organize, and manage your website bookmarks securely." />
    <meta property="twitter:image" content="/og-image.jpg" />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="RBookmark" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | RBookmark - Bookmarker App</title>
    
    <!-- Smooth View Transitions -->
    <ClientRouter />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Scripts for Exporting -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" defer></script>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest" defer></script>
  </head>
  <body class="flex flex-col md:flex-row min-h-screen md:overflow-hidden relative bg-surface-950 text-text-main">
    
    {isSupabaseConfigured && <Auth />}

    <!-- Sidebar -->
    <aside class="glass-panel m-4 w-full md:w-64 flex-shrink-0 flex flex-col z-10 sticky top-4 h-[calc(100vh-2rem)] overflow-y-auto hidden md:flex">
      <div class="p-6 flex items-center justify-between border-b border-surface-700/50">
        <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
          <div class="bg-primary-500/20 text-primary-400 p-2 rounded-xl">
            <i data-lucide="bookmark"></i>
          </div>
          <h1 class="font-bold text-xl tracking-tight text-text-main">AI Bookmark</h1>
        </a>
      </div>
      
      <div class="flex-1 overflow-y-auto p-4 flex flex-col gap-6" id="sidebar-nav">
        <!-- Main Navigation -->
        <div>
          <nav class="flex flex-col gap-1">
            <a href="/clipboard" class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-all group ${Astro.url.pathname === '/clipboard' ? 'bg-surface-800 text-text-main border border-surface-700 shadow-md shadow-black/20' : 'text-surface-500 hover:text-text-main hover:bg-surface-700/50 border border-transparent'}`}>
              <i data-lucide="clipboard-list" class={`w-5 h-5 ${Astro.url.pathname === '/clipboard' ? 'text-primary-500' : 'group-hover:text-primary-500'} transition-colors`}></i>
              <span class="font-medium">Clipboard</span>
            </a>
          </nav>
        </div>

        <!-- Custom Folders -->
        <div>
          <div class="flex items-center justify-between mb-3 px-2">
            <h2 class="text-xs font-semibold text-surface-400 uppercase tracking-wider">My Folders</h2>
            <button id="btn-new-folder-sidebar" class="text-surface-400 hover:text-primary-500 transition-colors" title="Create Folder">
              <i data-lucide="folder-plus" class="w-4 h-4"></i>
            </button>
          </div>
          <nav class="flex flex-col gap-1" id="custom-folders-list">
            <div class="px-3 py-2 text-xs text-surface-500 italic">Loading folders...</div>
          </nav>
        </div>
      </div>
      
      <div class="p-4 border-t border-surface-700/50 flex flex-col gap-3">
        <button id="btn-add-bookmark-global" class="w-full flex items-center justify-center gap-2 bg-primary-600 hover:bg-primary-500 text-white px-4 py-2.5 rounded-xl font-medium transition-all shadow-lg shadow-primary-500/20 active:scale-95">
          <i data-lucide="plus" class="w-4 h-4"></i> New Bookmark
        </button>
        {isSupabaseConfigured && (
          <button id="btn-logout" class="w-full flex items-center justify-center gap-2 bg-surface-800 hover:bg-surface-700 text-surface-400 hover:text-red-400 px-4 py-2 rounded-xl text-sm font-medium transition-all">
            <i data-lucide="log-out" class="w-4 h-4"></i> Sign Out
          </button>
        )}
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-4 md:p-8 md:h-screen md:overflow-y-auto relative z-0 pb-28 md:pb-8">
      <!-- Ambient background glow -->
      <div class="fixed top-[-20%] right-[-10%] w-[600px] h-[600px] rounded-full bg-primary-600/10 blur-[120px] pointer-events-none -z-10"></div>
      <div class="fixed bottom-[-20%] left-[10%] w-[500px] h-[500px] rounded-full bg-purple-600/10 blur-[120px] pointer-events-none -z-10"></div>
      
      {!isSupabaseConfigured && <SetupSupabase />}
      <slot />
    </main>
    

    <!-- Mobile Bottom Bar -->
    <div class="md:hidden glass-panel rounded-none border-x-0 border-b-0 fixed bottom-0 left-0 w-full z-50 flex items-center justify-around p-3 pb-safe">
      <a href="/" class={`flex flex-col items-center gap-1 ${Astro.url.pathname === '/' ? 'text-primary-500' : 'text-surface-400 hover:text-primary-500'}`}>
        <i data-lucide="home" class="w-5 h-5"></i>
        <span class="text-[10px]">Home</span>
      </a>
      <a href="/clipboard" class={`flex flex-col items-center gap-1 ${Astro.url.pathname === '/clipboard' ? 'text-primary-500' : 'text-surface-400 hover:text-primary-500'}`}>
        <i data-lucide="clipboard-list" class="w-5 h-5"></i>
        <span class="text-[10px]">Clipboard</span>
      </a>
      <button id="btn-add-bookmark-mobile" class="bg-primary-500 text-white p-3 rounded-full shadow-lg shadow-primary-500/30 transform -translate-y-4">
        <i data-lucide="plus" class="w-6 h-6"></i>
      </button>
      <button id="btn-new-folder-mobile" class="flex flex-col items-center gap-1 text-surface-400 hover:text-primary-500">
        <i data-lucide="folder-plus" class="w-5 h-5"></i>
        <span class="text-[10px]">Folder</span>
      </button>
    </div>

    <!-- Global Modals Container -->
    <div id="modals-container"></div>

    <script>
      import { getFolders, type Folder } from '../lib/dataClient';
      import { supabase } from '../lib/supabaseClient';

      // Make setup function reusable across navigations
      function setupApp() {
        // @ts-ignore
        if (window.lucide) window.lucide.createIcons();
        
        loadCustomFolders();
      }

      async function loadCustomFolders() {
        const container = document.getElementById('custom-folders-list');
        if (!container) return;

        container.innerHTML = `
          <div class="px-3 py-2 flex flex-col gap-2">
            <div class="w-full h-8 rounded-lg bg-surface-800 animate-pulse"></div>
            <div class="w-3/4 h-8 rounded-lg bg-surface-800 animate-pulse"></div>
            <div class="w-5/6 h-8 rounded-lg bg-surface-800 animate-pulse"></div>
          </div>
        `;

        let folders = await getFolders();
        folders = folders.filter((f: Folder) => f.name.toLowerCase() !== 'clipboard');
        
        container.innerHTML = folders.length ? '' : '<div class="px-3 py-2 text-xs text-surface-500 italic">No custom folders yet.</div>';
        
        folders.forEach((folder: Folder) => {
          const a = document.createElement('a');
          a.href = `/folder?id=${encodeURIComponent(folder.id)}`;
          
          let icon = 'folder';

          
          const isActive = window.location.pathname === '/folder' && window.location.search.includes(folder.id);
          const activeClasses = isActive 
            ? 'bg-surface-800 text-text-main border border-surface-700 shadow-md shadow-black/20' 
            : 'text-surface-500 hover:text-text-main hover:bg-surface-700/50 border border-transparent';

          a.className = `flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-all group ${activeClasses}`;
          a.innerHTML = `<i data-lucide="${icon}" class="w-4 h-4 ${isActive ? 'text-primary-500' : 'group-hover:text-primary-500'} transition-colors"></i> <span class="truncate">${folder.name}</span>`;
          container.appendChild(a);
        });
        
        // Re-initialize icons for new DOM elements
        // @ts-ignore
        if (window.lucide) window.lucide.createIcons();
      }

      document.addEventListener('DOMContentLoaded', setupApp);
      document.addEventListener('astro:page-load', setupApp); // Handle View Transitions
      window.addEventListener('foldersUpdated', loadCustomFolders);
      window.addEventListener('auth-changed', loadCustomFolders);
      
      // Setup event listeners that shouldn't be inside async setupApp
      function attachListeners() {
        const btnGlobal = document.getElementById('btn-add-bookmark-global');
        const btnMobile = document.getElementById('btn-add-bookmark-mobile');
        const btnNewFolderSidebar = document.getElementById('btn-new-folder-sidebar');
        const btnNewFolderMobile = document.getElementById('btn-new-folder-mobile');
        const btnLogout = document.getElementById('btn-logout');
        
        if (btnGlobal) btnGlobal.addEventListener('click', () => window.dispatchEvent(new CustomEvent('openBookmarkModal')));
        if (btnMobile) btnMobile.addEventListener('click', () => window.dispatchEvent(new CustomEvent('openBookmarkModal')));
        if (btnNewFolderSidebar) btnNewFolderSidebar.addEventListener('click', () => window.dispatchEvent(new CustomEvent('openFolderModal')));
        if (btnNewFolderMobile) btnNewFolderMobile.addEventListener('click', () => window.dispatchEvent(new CustomEvent('openFolderModal')));
        
        if (btnLogout) {
          btnLogout.addEventListener('click', async () => {
            (btnLogout as HTMLButtonElement).disabled = true;
            btnLogout.innerHTML = `<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Signing Out...`;
            // @ts-ignore
            if (window.lucide) window.lucide.createIcons();
            
            await supabase?.auth.signOut();
            window.location.reload();
          });
        }

      }
      document.addEventListener('astro:page-load', attachListeners);
      document.addEventListener('DOMContentLoaded', attachListeners);
      
    </script>
  </body>
</html>
